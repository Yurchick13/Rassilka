[Unit]
Description=RED OS Vacation Notifier
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/vacation-registry/redos_notifier
Environment=SERVER_HTTP_URL=http://192.168.76.95:8000
Environment=SERVER_WS_URL=ws://192.168.76.95:8000/ws/registry
ExecStart=/usr/bin/python3 /opt/vacation-registry/redos_notifier/notifier.py
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
