SERVER_HTTP_URL=http://192.168.76.95:8000
SERVER_WS_URL=ws://192.168.76.95:8000/ws/registry
# Если на сервере включен heartbeat-токен, укажите его здесь
# CLIENT_HEARTBEAT_TOKEN=change-me
# Можно отключить автообновление на клиенте (1/0)
NOTIFIER_AUTO_UPDATE_ENABLED=1
# Требовать цифровую подпись обновлений Windows:
# 1 = строго обязательно (рекомендуется только после внедрения code signing),
# 0 = разрешить обновление без подписи (удобно для внутренней сети).
NOTIFIER_REQUIRE_SIGNED_UPDATES=0
# Интервал heartbeat в секундах
HEARTBEAT_INTERVAL_SECONDS=60
